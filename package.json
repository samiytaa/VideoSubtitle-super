{
  "name": "video-subtitle-extractor",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently \"npm run dev:api\" \"vite\"",
    "dev:api": "node scripts/dev-api.mjs",
    "build": "node scripts/build.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "preview": "vite preview",
    "electron": "electron .",
    "dist": "npm run build && electron-builder"
  },
  "dependencies": {
    "@tanstack/react-virtual": "^3.13.24",
    "@vitejs/plugin-vue": "^6.0.6",
    "immer": "^11.1.8",
    "jszip": "^3.10.1",
    "lucide-react": "^0.563.0",
    "pixelmatch": "^7.1.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "video.js": "^8.23.6",
    "vue": "^3.5.34"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "@tailwindcss/vite": "^4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.4.27",
    "chrome-devtools-mcp": "^0.26.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vitest": "^4.1.6"
  },
  "build": {
    "appId": "com.video.subtitle.extractor",
    "productName": "视频字幕截取工具",
    "icon": "integrated/web2api/public/favicon.ico",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "extraResources": [
      {
        "from": "integrated/web2api",
        "to": "app-resources/integrated/web2api",
        "filter": [
          "src/**/*",
          "public/**/*",
          "package.json",
          "node_modules/ffmpeg-static/**/*"
        ]
      }
    ],
    "win": {
      "icon": "integrated/web2api/public/favicon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64"
          ]
        }
      ],
      "signtoolOptions": {
        "sign": null
      }
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
